# ── LLM provider ─────────────────────────────────────────────────────────────
# Choose one: openai | claude | gemini
LLM_PROVIDER=openai

# ── API keys (fill in only the provider you chose above) ─────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# ── Model overrides (optional — defaults shown) ───────────────────────────────
# OPENAI_MODEL=gpt-4o
# CLAUDE_MODEL=claude-3-5-sonnet-20241022
# GEMINI_MODEL=gemini-1.5-flash

# ── Screenshot region (pixels) ───────────────────────────────────────────────
# Run `python setup_region.py` to find the right values for your setup.
# (0, 0) = top-left corner of primary monitor.
SCREENSHOT_LEFT=0
SCREENSHOT_TOP=0
SCREENSHOT_WIDTH=1920
SCREENSHOT_HEIGHT=1080

# ── Browser mode: calibrated scroll-capture region and input behavior ───────
# Browser mode captures a visible browser page region, then scrolls and captures
# additional frames until the page stops changing.
BROWSER_REGION_LEFT=0
BROWSER_REGION_TOP=0
BROWSER_REGION_WIDTH=1920
BROWSER_REGION_HEIGHT=1080

# Click point inside BROWSER_REGION to focus the page before scrolling.
BROWSER_PAGE_CLICK_X=20
BROWSER_PAGE_CLICK_Y=20

# Scrolling mode: keyboard (default) or mouse
BROWSER_SCROLL_INPUT_MODE=keyboard
BROWSER_SCROLL_KEY=PageDown
BROWSER_SCROLL_MOUSE_DELTA=-1200

# Wait after each scroll so lazy-loaded content can render.
BROWSER_SCROLL_DELAY_MS=5000

# Trim duplicated areas from each subsequent chunk.
BROWSER_SCROLL_OVERLAP=200
BROWSER_STICKY_HEADER_CROP=0

# Send Home once before capture starts.
BROWSER_SEND_HOME_BEFORE_CAPTURE=true

# ── Flask server ──────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=5000

# ── ngrok (optional remote access) ───────────────────────────────────────────
USE_NGROK=false
NGROK_AUTH_TOKEN=
