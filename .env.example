# ── LLM provider ─────────────────────────────────────────────────────────────
# Choose one: openai | claude | gemini
LLM_PROVIDER=openai

# ── API keys (fill in only the provider you chose above) ─────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# ── Model overrides (optional — defaults shown) ───────────────────────────────
# OPENAI_MODEL=gpt-4o
# CLAUDE_MODEL=claude-3-5-sonnet-20241022
# GEMINI_MODEL=gemini-1.5-flash

# ── Screenshot region (pixels) ───────────────────────────────────────────────
# Run `python setup_region.py` to find the right values for your setup.
# (0, 0) = top-left corner of primary monitor.
SCREENSHOT_LEFT=0
SCREENSHOT_TOP=0
SCREENSHOT_WIDTH=1920
SCREENSHOT_HEIGHT=1080

# ── Flask server ──────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=5000

# ── ngrok (optional remote access) ───────────────────────────────────────────
USE_NGROK=false
NGROK_AUTH_TOKEN=
